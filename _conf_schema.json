        },
        "hint": "除非目标接口有特殊要求，否则建议保持默认值。"
      }
    }
  },
  "debug": {
    "description": "🛠️ 调试与诊断",
    "type": "object",
    "hint": "仅在排查接口字段或音乐解析问题时临时开启。",
