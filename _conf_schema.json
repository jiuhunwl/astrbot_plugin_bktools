      },
      "max_chars": {
        "description": "单次日志最大字符数",
        "type": "int",
        "default": 800,
        "condition": {
          "enable": true
        },
        "slider": {
          "min": 100,
          "max": 5000,
          "step": 100
        },
        "hint": "限制日志长度，避免完整响应刷屏或泄露过多数据。"
      }
    }
  }
