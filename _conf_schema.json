{
  "trigger": {
    "description": "⚡ 自动解析与去重",
    "type": "object",
    "hint": "控制插件在聊天中自动识别哪些链接，以及如何避免同一链接被重复解析。",
    "items": {
      "auto_short_video": {
        "description": "自动解析短视频链接",
        "type": "bool",
        "default": true,
        "hint": "消息中出现抖音、快手、小红书、即梦、千问、视频号等支持域名时自动解析。"
      },
      "auto_douyin_profile": {
        "description": "自动解析抖音主页",
        "type": "bool",
        "default": true,
        "hint": "识别抖音用户主页链接并打包发送作品列表。"
      },
      "auto_music_link": {
        "description": "自动解析音乐分享链接",
        "type": "bool",
        "default": true,
        "hint": "支持网易云、QQ 音乐、汽水音乐、酷我等分享链接。"
      },
      "dedup_enable": {
        "description": "启用链接去重",
        "type": "bool",
        "default": true,
        "hint": "避免命令处理器、自动触发或短时间重复消息造成重复解析。"
      },
      "dedup_window_sec": {
        "description": "去重时间窗口（秒）",
        "type": "int",
        "default": 30,
        "condition": {
          "dedup_enable": true
        },
        "slider": {
          "min": 5,
          "max": 300,
          "step": 5
        },
        "hint": "同一链接在此时间内只处理一次。"
      }
    }
  },
  "message": {
    "description": "💬 消息输出与合并转发",
    "type": "object",
    "hint": "设置解析提示、合并转发重试、媒体展示数量和音乐语音消息。",
    "items": {
      "opening_enable": {
        "description": "显示“正在解析”提示",
        "type": "bool",
        "default": true,
        "hint": "关闭后将直接等待解析结果，群聊消息更简洁。"
      },
      "opening_text": {
        "description": "解析提示文字",
        "type": "string",
        "default": "正在解析，请稍候…",
        "condition": {
          "opening_enable": true
        },
        "hint": "插件会自动添加“BkTools：”前缀。"
      },
      "pack_forward": {
        "description": "使用合并转发发送解析结果",
        "type": "bool",
        "default": true,
        "hint": "推荐开启。打包失败会自动重试；全部失败后仅发送接口原始 JSON，不会逐作品刷屏。",
        "obvious_hint": true
      },
      "advanced_settings": {
        "description": "显示高级消息设置",
        "type": "bool",
        "default": false,
        "hint": "展开重试间隔、封面、原链接、展示数量和语音限制等细节设置。"
      },
      "pack_retry_count": {
        "description": "合并转发重试次数",
        "type": "int",
        "default": 2,
        "condition": {
          "pack_forward": true,
          "advanced_settings": true
        },
        "slider": {
          "min": 0,
          "max": 5,
          "step": 1
        },
        "hint": "默认重试 2 次，即首次发送加 2 次重试，最多尝试 3 次。"
      },
      "pack_retry_delay_ms": {
        "description": "重试间隔（毫秒）",
        "type": "int",
        "default": 800,
        "condition": {
          "pack_forward": true,
          "advanced_settings": true
        },
        "slider": {
          "min": 0,
          "max": 5000,
          "step": 100
        },
        "hint": "建议保持 500-1500 毫秒，过短可能连续触发平台限流。"
      },
      "short_video_text_metadata": {
        "description": "显示作品标题、作者和文案",
        "type": "bool",
        "default": true,
        "hint": "关闭后仅发送视频、图片或资源链接。"
      },
      "pack_send_video": {
        "description": "使用 Video 组件发送视频",
        "type": "bool",
        "default": true,
        "hint": "关闭后视频以文本直链发送；开启时依赖当前平台对 Video.fromURL 的支持。"
      },
      "pack_include_cover": {
        "description": "视频结果附带封面",
        "type": "bool",
        "default": true,
        "condition": {
          "advanced_settings": true
        },
        "hint": "有视频资源时，在视频节点前加入作品封面。"
      },
      "pack_append_original_link": {
        "description": "附带原始分享链接",
        "type": "bool",
        "default": true,
        "condition": {
          "advanced_settings": true
        },
        "hint": "在作品文字信息末尾保留用户发送的原始链接，便于回溯。"
      },
      "max_images_per_work": {
        "description": "每个作品最多展示图片数",
        "type": "int",
        "default": 9,
        "condition": {
          "advanced_settings": true
        },
        "slider": {
          "min": 1,
          "max": 30,
          "step": 1
        },
        "hint": "仅限制消息展示数量，不会修改接口返回的完整 JSON。"
      },
      "search_result_limit": {
        "description": "作品列表/搜歌最大展示数",
        "type": "int",
        "default": 8,
        "condition": {
          "advanced_settings": true
        },
        "slider": {
          "min": 1,
          "max": 20,
          "step": 1
        },
        "hint": "同时用于抖音主页作品列表和网易云搜索结果。"
      },
      "send_voice_message": {
        "description": "音乐解析后发送语音消息",
        "type": "bool",
        "default": true,
        "hint": "需要服务器已安装 pydub 与 ffmpeg；失败时仍会保留音乐直链。"
      },
      "voice_max_duration": {
        "description": "语音最大时长（秒）",
        "type": "int",
        "default": 60,
        "condition": {
          "send_voice_message": true,
          "advanced_settings": true
        },
        "slider": {
          "min": 10,
          "max": 300,
          "step": 10
        },
        "hint": "超过此时长时会自动截断。"
      },
      "voice_max_size_mb": {
        "description": "音频下载大小上限（MB）",
        "type": "int",
        "default": 10,
        "condition": {
          "send_voice_message": true,
          "advanced_settings": true
        },
        "slider": {
          "min": 1,
          "max": 100,
          "step": 1
        },
        "hint": "超过限制时不下载转换，避免占用过多内存和带宽。"
      }
    }
  },
  "short_video": {
    "description": "🎬 短视频解析接口",
    "type": "object",
    "hint": "普通使用只需确认接口地址；字段路径仅在接口返回结构不同或自行部署接口时调整。",
    "items": {
      "endpoint": {
        "description": "短视频解析接口地址",
        "type": "string",
        "default": "https://api.bugpk.com/api/short_videos",
        "hint": "填写完整接口地址，不要在末尾手动拼接 ?url= 参数。",
        "obvious_hint": true
      },
      "request_method": {
        "description": "接口请求方式",
        "type": "string",
        "options": [
          "GET",
          "POST"
