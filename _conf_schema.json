  "alist": {
    "description": "☁️ Alist 视频上传（可选）",
    "type": "object",
    "hint": "将视频先上传到自己的 Alist，再发送可访问直链。未使用 Alist 时保持关闭即可。",
    "items": {
      "enable": {
        "description": "启用 Alist 上传",
        "type": "bool",
        "default": false
      },
      "url": {
        "description": "Alist 服务地址",
        "type": "string",
        "default": "",
        "condition": {
          "enable": true
        },
        "hint": "例如 https://alist.example.com，不要填写后台管理路径。",
        "obvious_hint": true
      },
      "username": {
        "description": "Alist 用户名",
        "type": "string",
        "default": "",
        "condition": {
          "enable": true
        }
      },
      "password": {
        "description": "Alist 密码",
        "type": "string",
        "default": "",
        "condition": {
          "enable": true
        },
        "hint": "请使用权限受限的专用账号。"
      },
      "upload_path": {
        "description": "上传目录",
        "type": "string",
        "default": "/",
        "condition": {
          "enable": true
        },
        "hint": "例如 /视频分享。目标目录需已存在并允许写入。"
      },
      "upload_only": {
        "description": "仅发送 Alist 直链",
        "type": "bool",
        "default": false,
        "condition": {
          "enable": true
        },
        "hint": "开启后不再额外发送原视频组件，可减少重复流量。"
      },
      "chunk_size_mb": {
        "description": "上传分片大小（MB）",
        "type": "int",
        "default": 10,
        "condition": {
          "enable": true
        },
        "slider": {
          "min": 1,
          "max": 100,
          "step": 1
        },
        "hint": "一般建议 5-50 MB。"
      },
      "request_timeout": {
        "description": "上传超时时间（秒）",
        "type": "int",
        "default": 60,
        "condition": {
          "enable": true
        },
        "slider": {
          "min": 10,
          "max": 300,
          "step": 10
        }
      }
    }
  },
  "http": {
    "description": "🌐 网络请求",
    "type": "object",
    "hint": "统一控制解析接口请求超时和 User-Agent。",
    "items": {
      "timeout_sec": {
        "description": "接口请求超时（秒）",
