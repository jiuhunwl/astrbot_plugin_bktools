  "link_only_music": {
    "description": "🎧 QQ / 汽水 / 酷我音乐",
    "type": "object",
    "hint": "这些平台仅支持分享链接解析，不支持关键词搜索。",
    "items": {
      "qq_endpoint": {
        "description": "QQ 音乐解析接口",
