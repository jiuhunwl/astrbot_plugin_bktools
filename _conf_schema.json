  "video_threshold": {
    "description": "📦 视频发送策略",
    "type": "object",
    "hint": "控制大视频是直接作为视频发送，还是改为发送资源链接。",
    "items": {
      "force_link_enabled": {
        "description": "始终发送视频直链",
        "type": "bool",
        "default": false,
        "hint": "优先级最高。开启后不检测文件大小，所有视频都以文本链接发送。"
      },
      "threshold_enabled": {
        "description": "超过大小阈值时发送直链",
        "type": "bool",
        "default": true,
        "condition": {
          "force_link_enabled": false
        },
        "hint": "关闭后不执行 HEAD 大小检测，直接尝试发送视频组件。"
      },
      "threshold_mb": {
        "description": "视频大小阈值（MB）",
        "type": "int",
        "default": 100,
        "condition": {
          "force_link_enabled": false,
          "threshold_enabled": true
        },
        "slider": {
          "min": 10,
          "max": 500,
          "step": 10
        },
        "hint": "文件大于此值时改发直链，减少上传失败和群聊发送超时。"
      }
    }
  },
  "batch_output": {
    "description": "🧾 大批量内容输出",
    "type": "object",
    "hint": "当图集或实况数量过多时，可直接发送接口完整 JSON，避免生成过大的合并转发。",
    "items": {
      "direct_json_enabled": {
        "description": "超出数量时直接发送 JSON",
        "type": "bool",
        "default": false,
        "hint": "JSON 会作为一条消息发送，不会拆分为单个作品或图片。"
      },
      "image_count_threshold": {
        "description": "图集数量阈值",
        "type": "int",
        "default": 20,
        "condition": {
          "direct_json_enabled": true
        },
        "slider": {
          "min": 1,
          "max": 100,
          "step": 1
        }
      },
      "live_photo_count_threshold": {
        "description": "实况视频数量阈值",
        "type": "int",
        "default": 10,
        "condition": {
          "direct_json_enabled": true
        },
        "slider": {
          "min": 1,
          "max": 100,
          "step": 1
        }
      }
    }
  },
