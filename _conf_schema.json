{
  "group_control": {
    "description": "👥 群聊启用范围与单群配置",
    "type": "object",
    "hint": "默认对所有群启用。可切换为仅配置的群启用，也可为任意群单独覆盖功能和参数。",
    "items": {
      "mode": {
        "description": "群聊启用模式",
        "type": "string",
        "options": [
          "all",
          "selected"
        ],
        "labels": [
          "所有群默认启用",
          "仅单群配置列表中的群启用"
        ],
        "default": "all",
        "hint": "不做任何设置时保持“所有群默认启用”，与旧版本行为一致。",
        "obvious_hint": true
      },
      "private_chat_enabled": {
        "description": "允许私聊使用插件",
        "type": "bool",
        "default": true,
        "hint": "此开关独立于群聊启用模式。"
      },
      "disabled_message": {
        "description": "未启用时的命令提示",
        "type": "string",
        "default": "当前群未启用 BKtools，请联系管理员调整插件群聊设置。",
        "hint": "自动识别链接时保持静默；用户主动执行命令时发送此提示。"
      },
      "group_overrides": {
        "description": "单群配置列表",
        "type": "template_list",
        "hint": "“所有群默认启用”模式下用于单群覆盖或禁用；“仅配置群启用”模式下，此列表同时作为群白名单。",
        "templates": {
          "group": {
            "name": "添加单群配置",
            "hint": "填写群号后，可控制该群是否启用插件、开放哪些功能，以及覆盖消息和解析参数。",
            "display_item": "group_id",
            "hide_hint_in_list": true,
            "items": {
              "group_id": {
                "description": "群号 / 群聊 ID",
                "type": "string",
                "default": "",
                "hint": "QQ 群填写群号；其他平台填写 AstrBot 事件中的 group_id。",
                "obvious_hint": true
              },
              "platform": {
                "description": "平台名称（可选）",
                "type": "string",
                "default": "",
                "hint": "留空匹配任意平台；需要区分同名群 ID 时填写 aiocqhttp、telegram、discord 等。"
              },
              "enabled": {
                "description": "该群启用插件",
                "type": "bool",
                "default": true,
                "hint": "所有群模式下可关闭某个群；仅配置群模式下必须开启才属于白名单。"
              },
              "features": {
                "description": "该群可用功能",
                "type": "object",
                "hint": "关闭后，自动解析与对应手动命令都会在该群停用。",
                "items": {
                  "short_video": {
                    "description": "短视频作品解析",
                    "type": "bool",
                    "default": true
                  },
                  "douyin_profile": {
                    "description": "抖音主页作品列表",
                    "type": "bool",
                    "default": true
                  },
                  "netease": {
                    "description": "网易云搜歌与点歌",
                    "type": "bool",
                    "default": true
                  },
                  "music": {
                    "description": "音乐分享链接解析",
                    "type": "bool",
                    "default": true
                  }
                }
              },
              "behavior": {
                "description": "常用行为覆盖",
                "type": "object",
                "hint": "“继承全局”会使用设置页其他分组中的全局值。",
                "items": {
                  "auto_short_video": {
                    "description": "自动解析短视频",
                    "type": "string",
                    "options": ["inherit", "enable", "disable"],
                    "labels": ["继承全局", "强制开启", "强制关闭"],
                    "default": "inherit"
                  },
                  "auto_douyin_profile": {
                    "description": "自动解析抖音主页",
                    "type": "string",
                    "options": ["inherit", "enable", "disable"],
                    "labels": ["继承全局", "强制开启", "强制关闭"],
                    "default": "inherit"
                  },
                  "auto_music_link": {
                    "description": "自动解析音乐链接",
                    "type": "string",
                    "options": ["inherit", "enable", "disable"],
                    "labels": ["继承全局", "强制开启", "强制关闭"],
                    "default": "inherit"
                  },
                  "pack_forward": {
                    "description": "合并转发",
                    "type": "string",
                    "options": ["inherit", "enable", "disable"],
                    "labels": ["继承全局", "强制开启", "强制关闭"],
                    "default": "inherit"
                  },
                  "opening_enable": {
                    "description": "“正在解析”提示",
                    "type": "string",
                    "options": ["inherit", "enable", "disable"],
                    "labels": ["继承全局", "强制开启", "强制关闭"],
                    "default": "inherit"
                  },
                  "send_voice_message": {
                    "description": "音乐语音消息",
                    "type": "string",
                    "options": ["inherit", "enable", "disable"],
                    "labels": ["继承全局", "强制开启", "强制关闭"],
                    "default": "inherit"
                  },
                  "force_link_enabled": {
                    "description": "视频始终发送直链",
                    "type": "string",
                    "options": ["inherit", "enable", "disable"],
                    "labels": ["继承全局", "强制开启", "强制关闭"],
                    "default": "inherit"
                  },
                  "direct_json_enabled": {
                    "description": "大批量内容直接发 JSON",
                    "type": "string",
                    "options": ["inherit", "enable", "disable"],
                    "labels": ["继承全局", "强制开启", "强制关闭"],
                    "default": "inherit"
                  }
                }
              },
              "override_json": {
                "description": "高级配置覆盖（JSON）",
                "type": "string",
                "default": "{}",
                "editor_mode": true,
                "editor_language": "json",
                "editor_theme": "vs-light",
                "hint": "可覆盖业务配置，例如 {\"message\":{\"max_images_per_work\":3},\"video_threshold\":{\"threshold_mb\":50}}。出于安全原因不能覆盖 group_control 和 security；常用行为选择项优先级更高。"
              }
            }
          }
        }
      }
    }
  },
  "security": {
    "description": "🛡️ 权限、安全与资源限制",
    "type": "object",
    "hint": "保护管理命令、限制单群并发，并定期清理长期运行产生的内存缓存。URL 公网校验始终启用。",
    "items": {
      "management_permission": {
        "description": "管理命令权限",
        "type": "string",
        "options": ["admin_only", "allowlist_only", "everyone"],
        "labels": ["群主/群管理员或授权用户", "仅授权用户列表", "所有成员（不推荐）"],
        "default": "admin_only",
        "hint": "控制 /bk停止解析、/bk清理缓存、/bk状态 和 /bk诊断。",
        "obvious_hint": true
      },
      "allow_group_admins": {
        "description": "允许群主和群管理员使用管理命令",
        "type": "bool",
        "default": true,
        "condition": {
          "management_permission": "admin_only"
        }
      },
      "admin_user_ids": {
        "description": "全局授权用户 ID",
        "type": "list",
        "default": [],
        "hint": "每行填写一个用户 ID。授权用户可在群聊和私聊中执行管理命令。"
      },
      "max_concurrent_tasks_per_scope": {
        "description": "每个群/私聊最大并发解析数",
        "type": "int",
        "default": 2,
        "slider": {
          "min": 1,
          "max": 10,
          "step": 1
        },
        "hint": "超过限制的解析会等待，避免同时下载大量媒体拖垮机器人。"
      },
      "advanced_settings": {
        "description": "显示高级资源管理设置",
        "type": "bool",
        "default": false
      },
      "cache_prune_interval_sec": {
        "description": "缓存回收检查间隔（秒）",
        "type": "int",
        "default": 60,
        "condition": {
          "advanced_settings": true
        },
        "slider": {
          "min": 10,
          "max": 600,
          "step": 10
        }
      },
      "runtime_cache_ttl_sec": {
        "description": "运行时缓存有效期（秒）",
        "type": "int",
        "default": 600,
        "condition": {
          "advanced_settings": true
        },
        "slider": {
          "min": 30,
          "max": 3600,
          "step": 30
        },
        "hint": "用于去重记录和点歌候选缓存，过期后自动释放。"
      }
    }
  },
  "trigger": {
    "description": "⚡ 自动解析与去重",
    "type": "object",
    "hint": "控制插件在聊天中自动识别哪些链接，以及如何避免同一链接被重复解析。",
    "items": {
      "auto_short_video": {
        "description": "自动解析短视频链接",
        "type": "bool",
        "default": true,
        "hint": "消息中出现抖音、快手、小红书、即梦、千问、视频号等支持域名时自动解析。"
      },
      "auto_douyin_profile": {
        "description": "自动解析抖音主页",
        "type": "bool",
        "default": true,
        "hint": "识别抖音用户主页链接并打包发送作品列表。"
      },
      "auto_music_link": {
        "description": "自动解析音乐分享链接",
        "type": "bool",
        "default": true,
        "hint": "支持网易云、QQ 音乐、汽水音乐、酷我等分享链接。"
      },
      "dedup_enable": {
        "description": "启用链接去重",
        "type": "bool",
        "default": true,
        "hint": "避免命令处理器、自动触发或短时间重复消息造成重复解析。"
      },
      "dedup_window_sec": {
        "description": "去重时间窗口（秒）",
        "type": "int",
        "default": 30,
        "condition": {
          "dedup_enable": true
        },
        "slider": {
          "min": 5,
          "max": 300,
          "step": 5
        },
        "hint": "同一链接在此时间内只处理一次。"
      }
    }
  },
  "message": {
    "description": "💬 消息输出与合并转发",
    "type": "object",
    "hint": "设置解析提示、合并转发重试、媒体展示数量和音乐语音消息。",
    "items": {
      "opening_enable": {
        "description": "显示“正在解析”提示",
        "type": "bool",
        "default": true,
        "hint": "关闭后将直接等待解析结果，群聊消息更简洁。"
      },
      "opening_text": {
        "description": "解析提示文字",
        "type": "string",
        "default": "正在解析，请稍候…",
        "condition": {
          "opening_enable": true
        },
        "hint": "插件会自动添加“BkTools：”前缀。"
      },
      "pack_forward": {
        "description": "使用合并转发发送解析结果",
        "type": "bool",
        "default": true,
        "hint": "推荐开启。打包失败会自动重试；全部失败后仅发送接口原始 JSON，不会逐作品刷屏。",
        "obvious_hint": true
      },
      "advanced_settings": {
        "description": "显示高级消息设置",
        "type": "bool",
        "default": false,
        "hint": "展开重试间隔、封面、原链接、展示数量和语音限制等细节设置。"
      },
      "pack_retry_count": {
        "description": "旧版合并重试次数（已停用）",
        "type": "int",
        "default": 0,
        "condition": {
          "pack_forward": true,
          "advanced_settings": true
        },
        "slider": {
          "min": 0,
          "max": 5,
          "step": 1
        },
        "hint": "为避免平台已接收但接口抛错造成重复消息，v1.6.2 起不再对 send() 异常盲目重试。该字段仅为旧配置兼容保留。"
      },
      "pack_retry_delay_ms": {
        "description": "旧版重试间隔（已停用）",
        "type": "int",
        "default": 800,
        "condition": {
          "pack_forward": true,
          "advanced_settings": true
        },
        "slider": {
          "min": 0,
          "max": 5000,
          "step": 100
        },
        "hint": "该字段仅为旧配置兼容保留，当前版本不会执行不确定状态下的自动重试。"
      },
      "short_video_text_metadata": {
        "description": "显示作品标题、作者和文案",
        "type": "bool",
        "default": true,
        "hint": "关闭后仅发送视频、图片或资源链接。"
      },
      "pack_send_video": {
        "description": "使用 Video 组件发送视频",
        "type": "bool",
        "default": true,
        "hint": "关闭后视频以文本直链发送；开启时依赖当前平台对 Video.fromURL 的支持。"
      },
      "pack_include_cover": {
        "description": "视频结果附带封面",
        "type": "bool",
        "default": true,
        "condition": {
          "advanced_settings": true
        },
        "hint": "有视频资源时，在视频节点前加入作品封面。"
      },
      "pack_append_original_link": {
        "description": "附带原始分享链接",
        "type": "bool",
        "default": true,
        "condition": {
          "advanced_settings": true
        },
        "hint": "在作品文字信息末尾保留用户发送的原始链接，便于回溯。"
      },
      "max_images_per_work": {
        "description": "每个作品最多展示图片数",
        "type": "int",
        "default": 9,
        "condition": {
          "advanced_settings": true
        },
        "slider": {
          "min": 1,
          "max": 30,
          "step": 1
        },
        "hint": "仅限制消息展示数量，不会修改接口返回的完整 JSON。"
      },
      "search_result_limit": {
        "description": "作品列表/搜歌最大展示数",
        "type": "int",
        "default": 8,
        "condition": {
          "advanced_settings": true
        },
        "slider": {
          "min": 1,
          "max": 20,
          "step": 1
        },
        "hint": "同时用于抖音主页作品列表和网易云搜索结果。"
      },
      "send_voice_message": {
        "description": "音乐解析后发送语音消息",
        "type": "bool",
        "default": true,
        "hint": "需要服务器已安装 pydub 与 ffmpeg；失败时仍会保留音乐直链。"
      },
      "voice_max_duration": {
        "description": "语音最大时长（秒）",
        "type": "int",
        "default": 60,
        "condition": {
          "send_voice_message": true,
          "advanced_settings": true
        },
        "slider": {
          "min": 10,
          "max": 300,
          "step": 10
        },
        "hint": "超过此时长时会自动截断。"
      },
      "voice_max_size_mb": {
        "description": "音频下载大小上限（MB）",
        "type": "int",
        "default": 10,
        "condition": {
          "send_voice_message": true,
          "advanced_settings": true
        },
        "slider": {
          "min": 1,
          "max": 100,
          "step": 1
        },
        "hint": "超过限制时不下载转换，避免占用过多内存和带宽。"
      }
    }
  },
  "short_video": {
    "description": "🎬 短视频解析接口",
    "type": "object",
    "hint": "普通使用只需确认接口地址；字段路径仅在接口返回结构不同或自行部署接口时调整。",
    "items": {
      "endpoint": {
        "description": "短视频解析接口地址",
        "type": "string",
        "default": "https://api.bugpk.com/api/short_videos",
        "hint": "填写完整接口地址，不要在末尾手动拼接 ?url= 参数。",
        "obvious_hint": true
      },
      "request_method": {
        "description": "接口请求方式",
        "type": "string",
        "options": [
          "GET",
          "POST"
        ],
        "labels": [
          "GET 查询参数",
          "POST 表单"
        ],
        "default": "GET"
      },
      "advanced_settings": {
        "description": "显示高级字段映射",
        "type": "bool",
        "default": false,
        "hint": "仅当自定义接口的参数名或 JSON 结构与默认值不一致时开启。"
      },
      "url_param_name": {
        "description": "作品链接参数名",
        "type": "string",
        "default": "url",
        "condition": {
          "advanced_settings": true
        },
        "hint": "接口接收作品分享链接时使用的参数名。"
      },
      "path_code": {
        "description": "业务状态码路径",
        "type": "string",
        "default": "code",
        "condition": {
          "advanced_settings": true
        }
      },
      "success_codes": {
        "description": "成功状态码",
        "type": "string",
        "default": "200",
        "condition": {
          "advanced_settings": true
        },
        "hint": "多个状态码使用英文逗号分隔，例如 200,0。"
      },
      "path_msg": {
        "description": "提示信息路径",
        "type": "string",
        "default": "msg",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_data_root": {
        "description": "作品数据根路径",
        "type": "string",
        "default": "data",
        "condition": {
          "advanced_settings": true
        },
        "hint": "标题、作者、封面等字段默认从此对象内读取。"
      },
      "profile_items_path": {
        "description": "主页作品列表路径",
        "type": "string",
        "default": "",
        "condition": {
          "advanced_settings": true
        },
        "hint": "留空时自动兼容 data、data.items、data.works、data.aweme_list 等常见结构。"
      },
      "path_title": {
        "description": "标题字段路径",
        "type": "string",
        "default": "title",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_desc": {
        "description": "文案字段路径",
        "type": "string",
        "default": "desc",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_type": {
        "description": "资源类型字段路径",
        "type": "string",
        "default": "type",
        "condition": {
          "advanced_settings": true
        },
        "hint": "期望值为 video、image 或 live。"
      },
      "path_author_name": {
        "description": "作者昵称字段路径",
        "type": "string",
        "default": "author.name",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_author_avatar": {
        "description": "作者头像字段路径",
        "type": "string",
        "default": "author.avatar",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_cover": {
        "description": "作品封面字段路径",
        "type": "string",
        "default": "cover",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_video_url": {
        "description": "主视频直链字段路径",
        "type": "string",
        "default": "url",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_video_backup_list": {
        "description": "备用视频列表字段路径",
        "type": "string",
        "default": "video_backup",
        "condition": {
          "advanced_settings": true
        },
        "hint": "主视频直链为空时，从备用列表选择可用地址。"
      },
      "path_images_list": {
        "description": "图集列表字段路径",
        "type": "string",
        "default": "images",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_live_photo_list": {
        "description": "实况列表字段路径",
        "type": "string",
        "default": "live_photo",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_live_photo_video": {
        "description": "实况项内视频字段路径",
        "type": "string",
        "default": "video",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_music_title": {
        "description": "背景音乐标题字段路径",
        "type": "string",
        "default": "music.title",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_music_author": {
        "description": "背景音乐作者字段路径",
        "type": "string",
        "default": "music.author",
        "condition": {
          "advanced_settings": true
        }
      },
      "path_music_url": {
        "description": "背景音乐直链字段路径",
        "type": "string",
        "default": "music.url",
        "condition": {
          "advanced_settings": true
        }
      }
    }
  },
  "video_threshold": {
    "description": "📦 视频发送策略",
    "type": "object",
    "hint": "控制大视频是直接作为视频发送，还是改为发送资源链接。",
    "items": {
      "force_link_enabled": {
        "description": "始终发送视频直链",
        "type": "bool",
        "default": false,
